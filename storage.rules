rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Project images — owner only
    match /project_images/{userId}/{projectId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Avatars — owner only
    match /avatars/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
